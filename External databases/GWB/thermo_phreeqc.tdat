*         Hfo_wOH + Sr+2 + H2O = Hfo_wOSrOH + 2H+
*         log_k -17.60
* #   Barium
*         Hfo_sOH + Ba+2 = Hfo_sOHBa+2
*         log_k  5.46
* 
*         Hfo_wOH + Ba+2 = Hfo_wOBa+ + H+
*         log_k  -7.2                     # table 10.5
* #
* #   Cations from table 10.2
* #
* #   Cadmium
*         Hfo_sOH + Cd+2 = Hfo_sOCd+ + H+
*         log_k  0.47
* 
*         Hfo_wOH + Cd+2 = Hfo_wOCd+ + H+
