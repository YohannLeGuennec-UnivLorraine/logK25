* SURFACE_SPECIES
* #   All surface data from 
* #   Dzombak and Morel, 1990
* #
* #
* #   Acid-base data from table 5.7
* #
* #   strong binding site--Hfo_s, 
* 
*         Hfo_sOH = Hfo_sOH
*         log_k  0.0
* 
*         Hfo_sOH  + H+ = Hfo_sOH2+
*         log_k  7.29    # = pKa1,int
* 
*         Hfo_sOH = Hfo_sO- + H+
*         log_k  -8.93   # = -pKa2,int
* 
* #   weak binding site--Hfo_w
* 
*         Hfo_wOH = Hfo_wOH
*         log_k  0.0
* 
*         Hfo_wOH  + H+ = Hfo_wOH2+
*         log_k  7.29    # = pKa1,int
* 
*         Hfo_wOH = Hfo_wO- + H+
*         log_k  -8.93   # = -pKa2,int
* 
* ###############################################
* #             CATIONS                         #
* ###############################################
* #
* #   Cations from table 10.1 or 10.5
* #
* #   Calcium
*         Hfo_sOH + Ca+2 = Hfo_sOHCa+2
